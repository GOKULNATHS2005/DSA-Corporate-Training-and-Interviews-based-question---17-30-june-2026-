class Solution:

    def longestConsecutive(self, nums):

        numSet = set(nums)
        longest = 0

        for num in numSet:

            # Start of a sequence
            if num - 1 not in numSet:

                current = num
                length = 1

                while current + 1 in numSet:
                    current += 1
                    length += 1

                longest = max(longest, length)

        return longest


# Example
nums = [100, 4, 200, 1, 3, 2]

obj = Solution()
print("Longest Consecutive Sequence Length =", obj.longestConsecutive(nums))