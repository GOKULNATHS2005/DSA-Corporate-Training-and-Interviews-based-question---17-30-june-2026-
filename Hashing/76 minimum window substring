class Solution:

    def minWindow(self, s, t):

        left = 0
        minLen = float("inf")
        answer = ""

        count = {}

        # Store characters of t
        for ch in t:
            count[ch] = count.get(ch, 0) + 1

        required = len(count)

        for right in range(len(s)):

            if s[right] in count:
                count[s[right]] -= 1
                if count[s[right]] == 0:
                    required -= 1

            while required == 0:

                if right - left + 1 < minLen:
                    minLen = right - left + 1
                    answer = s[left:right + 1]

                if s[left] in count:
                    count[s[left]] += 1
                    if count[s[left]] > 0:
                        required += 1

                left += 1

        return answer


# Example
s = "ADOBECODEBANC"
t = "ABC"

obj = Solution()
print("Minimum Window:", obj.minWindow(s, t))