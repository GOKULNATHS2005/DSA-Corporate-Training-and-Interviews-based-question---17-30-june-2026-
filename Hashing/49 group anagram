class Solution:

    def groupAnagrams(self, strs):

        groups = {}

        for word in strs:
            key = "".join(sorted(word))

            if key not in groups:
                groups[key] = []

            groups[key].append(word)

        return list(groups.values())


# Example
words = ["eat", "tea", "tan", "ate", "nat", "bat"]

obj = Solution()
print(obj.groupAnagrams(words))