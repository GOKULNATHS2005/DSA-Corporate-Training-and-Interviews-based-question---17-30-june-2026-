from collections import deque
from typing import List

class Solution:
    def shortestPathLength(self, graph: List[List[int]]) -> int:
        V = len(graph)

        # BFS queue: (current_node, visited_mask)
        queue = deque()

        for i in range(V):
            queue.append((i, 1 << i))

        all_visited = (1 << V) - 1

        visited = [[False] * (1 << V) for _ in range(V)]

        for i in range(V):
            visited[i][1 << i] = True

        distance = 0

        while queue:
            size = len(queue)

            for _ in range(size):
                node, mask = queue.popleft()

                if mask == all_visited:
                    return distance

                for neighbor in graph[node]:
                    new_mask = mask | (1 << neighbor)

                    if not visited[neighbor][new_mask]:
                        visited[neighbor][new_mask] = True
                        queue.append((neighbor, new_mask))

            distance += 1

        return -1


# Driver Code
graph = [[1,2,3],[0],[0],[0]]

obj = Solution()
print("Shortest Path Length:", obj.shortestPathLength(graph))