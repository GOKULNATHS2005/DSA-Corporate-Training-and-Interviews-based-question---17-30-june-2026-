# Definition for a binary tree node.
class Solution:
    def maxPathSum(self, root: Optional[TreeNode]) -> int:
        maxSum = float('-inf')
        def dfs(node):
            nonlocal maxSum
            if not node:
                return 0
            l = max(0, dfs(node.left))
            r = max(0, dfs(node.right))
            maxSum = max(maxSum, l + r + node.val)
            return node.val + max(l, r)
        dfs(root)
        return maxSum